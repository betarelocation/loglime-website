\"}],[\"$\",\"p\",null,{\"children\":\"Your restaurant gets a fully branded iOS app on the Apple App Store and a fully branded Android app on Google Play, both published under your restaurant name and logo. Customers see your brand, not a generic marketplace.\"}]]}],[\"$\",\"div\",\"Direct ordering for pickup, delivery and dine-in\",{\"className\":\"pricing-detail-item\",\"children\":[[\"$\",\"h4\",null,{\"children\":\"Direct ordering for pickup, delivery and dine-in\"}],[\"$\",\"p\",null,{\"children\":\"Customers order directly through your app. Every order lands in your admin dashboard instantly. Loglime deducts zero commission, supports unlimited orders and adds no per-order fees.\"}]]}],[\"$\",\"div\",\"Restaurant admin dashboard\",{\"className\":\"pricing-detail-item\",\"children\":[[\"$\",\"h4\",null,{\"children\":\"Restaurant admin dashboard\"}],[\"$\",\"p\",null,{\"children\":\"Manage live orders, menu edits, stock updates, staff access and revenue reporting from a clean web dashboard built for busy restaurant owners.\"}]]}],[\"$\",\"div\",\"Smart menu with full customization\",{\"className\":\"pricing-detail-item\",\"children\":[[\"$\",\"h4\",null,{\"children\":\"Smart menu with full customization\"}],[\"$\",\"p\",null,{\"children\":\"Build categories, item photos, descriptions, prices, modifiers and availability toggles. Update prices, add specials or mark items sold out from any device.\"}]]}],[\"$\",\"div\",\"Customer app experience\",{\"className\":\"pricing-detail-item\",\"children\":[[\"$\",\"h4\",null,{\"children\":\"Customer app experience\"}],[\"$\",\"p\",null,{\"children\":\"Customers sign up with Google, Apple or phone OTP, browse your branded menu, customize orders, check out securely, track status and reorder faster next time.\"}]]}],[\"$\",\"div\",\"All payment gateways supported\",{\"className\":\"pricing-detail-item\",\"children\":[[\"$\",\"h4\",null,{\"children\":\"All payment gateways supported\"}],[\"$\",\"p\",null,{\"children\":\"Stripe,