"span\",null,{\"className\":\"pricing-faq-toggle\",\"aria-hidden\":\"true\"}]]}],[\"$\",\"p\",null,{\"children\":\"In year one with the early access Starter plan, fixed costs are approximately $273: $149 to Loglime, $99 to Apple for the Apple Developer Account and $25 to Google for the Google Play Developer Account. Firebase is expected to stay free at independent restaurant scale. Payment gateway fees are paid directly to the chosen gateway, not to Loglime. From year two onward, fixed costs are approximately $148 per year if the restaurant keeps optional Loglime maintenance active.\"}]]}],[\"$\",\"details\",\"Is there a monthly fee for Loglime?\",{\"className\":\"pricing-faq-item\",\"open\":false,\"children\":[[\"$\",\"summary\",null,{\"children\":[[\"$\",\"span\",null,{\"children\":\"Is there a monthly fee for Loglime?\"}],[\"$\",\"span\",null,{\"className\":\"pricing-faq-toggle\",\"aria-hidden\":\"true\"}]]}],[\"$\",\"p\",null,{\"children\":\"No. Loglime pricing is a one-time setup fee: $149 for Starter, $249 for Business and $399 for Pro during early access. There is no monthly subscription to Loglime. The only recurring Loglime cost is optional $49 per year maintenance from year two onward, covering minor updates, technical support and small compliance help.\"}]]}],[\"$\",\"details\",\"Does Loglime take commission on my orders?\",{\"className\":\"pricing-faq-item\",\"open\":false,\"children\":[[\"$\",\"summary\",null,{\"children\":[[\"$\",\"span\",null,{\"children\":\"Does Loglime take commission on my orders?\"}],[\"$\",\"span\",null,{\"className\":\"pricing-faq-toggle\",\"aria-hidden\":\"true\"}]]}],[\"$\",\"p\",null,{\"children\":\"Never. Loglime charges zero commission on every order your restaurant takes through its own app, on every plan and at every volume level. Payment goes directly to the restaurant payment gateway account. Loglime does not sit between the restaurant and the customer payment.\"}]]}],[\"$\",\"details\",\"What is the early access offer?\",{\"className\":\"pricing-faq-item\",\"open\":false,\"children\":[[\"$\",\"summary\",null,{\"children\":[[\"$\",\"span\",null,{\"children\":\"What is the early access offer?\"}],[\"$\",\"span\",null,{\"className\":\"pricing-faq-toggle\",\"aria-hidden\":\"true\"}]]}],[\"$\",\"p\",null,{\"children\":\"The first 10 independent restaurants receive 50% off standard setup pricing. Starter drops from $298 to $149, Business from $498 to $249 and Pro from $798 to $399. Early access closes when those spots are taken, and standard pricing applies after that.\"}]]}],[\"$\",\"details\",\"Can I upgrade my plan later?\",{\"className\":\"pricing-faq-item\",\"open\":false,\"children\":[[\"$\",\"summary\",null,{\"children\":[[\"$\",\"span\",null,{\"children\":\"Can I upgrade my plan later?\"}],[\"$\",\"span\",null,{\"className\":\"pricing-faq-toggle\",\"aria-hidden\":\"true\"}]]}],[\"$\",\"p\",null,{\"children\":\"Yes. A restaurant can upgrade from Starter to Business or Pro later and pay only the difference while early access pricing is active: $100 from Starter to Business, $250 from Starter to Pro and $150 from Business to Pro.\"}]]}],[\"$\",\"details\",\"What do I need to pay Apple and Google?\",{\"className\":\"pricing-faq-item\",\"open\":false,\"children\":[\"$L43\",\"$L44\"]}],\"$L45\",\"$L46\",\"$L47\",\"$L48\",\"$L49\",\"$L4a\"]}]]}]}]\n23:[\"$\",\"section\",null,{\"className\":\"pricing-final-cta\",\"children\":[\"$\",\"div\",null,{\"className\":\"container\",\"children\":[[\"$\",\"span\",null,{\"className\":\"pricing-pill\",\"children\":[[\"$\",\"$L2c\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z\",\"key\":\"1s2grr\"}],[\"path\",{\"d\":\"M20 2v4\",\"key\":\"1rf3ol\"}],[\"path\",{\"d\":\"M22 4h-4