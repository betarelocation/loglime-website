ck\",\"size\":14}],\" \",\"One-time payment\"]}],[\"$\",\"span\",\"0% commission forever\",{\"children\":[[\"$\",\"$L13\",null,{\"iconNode\":\"$3:props:children:props:children:5:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-check\",\"size\":14}],\" \",\"0% commission forever\"]}],[\"$\",\"span\",\"No monthly subscription\",{\"children\":[[\"$\",\"$L13\",null,{\"iconNode\":\"$3:props:children:props:children:5:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-check\",\"size\":14}],\" \",\"No monthly subscription\"]}],[\"$\",\"span\",\"iOS and Android included\",{\"children\":[[\"$\",\"$L13\",null,{\"iconNode\":\"$3:props:children:props:children:5:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-check\",\"size\":14}],\" \",\"iOS and Android included\"]}],[\"$\",\"span\",\"Your name on app stores\",{\"children\":[[\"$\",\"$L13\",null,{\"iconNode\":\"$3:props:children:props:children:5:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-check\",\"size\":14}],\" \",\"Your name on app stores\"]}],[\"$\",\"span\",\"7-day review window\",{\"children\":[[\"$\",\"$L13\",null,{\"iconNode\":\"$3:props:children:props:children:5:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-check\",\"size\":14}],\" \",\"7-day review window\"]}]]}]]}]}]\n4:[\"$\",\"section\",null,{\"className\":\"pricing-philosophy-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"container pricing-philosophy-grid\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"span\",null,{\"className\":\"pricing-eyebrow\",\"children\":\"Why we charge a one-time fee\"}],[\"$\",\"h2\",null,{\"children\":\"We built Loglime so your app pays for itself, not the other way around.\"}],[\"$\",\"p\",null,{\"children\":\"Most restaurant software companies make money by locking you into a monthly subscription forever. Some pile commission on top. Others charge per location, per feature or per user. The fees compound. The savings never materialise.\"}],[\"$\",\"p\",null,{\"children\":\"Loglime works differently. We charge a one-time setup fee because your restaurant app should become a permanent asset that saves money every month, not another recurring bill sitting next to marketplace fees.\"}]]}],[\"$\",\"div\",null,{\"className\":\"pricing-power-callout\",\"children\":[[\"$\",\"span\",null,{}],[\"$\",\"p\",null,{\"children\":\"DoorDash can charge up to 30% per order, every order, forever. Loglime early access starts at $149 once. The math is not complicated.\"}]]}]]}]}]\n5:[\"$\",\"section\",null,{\"className\":\"pricing-access-band\",\"children\":[[\"$\",\"div\",null,{\"className\":\"container pricing-access-grid\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"span\",null,{\"className\":\"pricing-eyebrow\",\"children\":\"Limited - first 10 restaurants only\"}],[\"$\",\"h2\",null,{\"children\":\"Early Access: 50% off setup for the first 10 independent restaurants.\"}],[\"$\",\"p\",null,{\"children\":\"We are onboarding our first 10 independent restaurants at 50% off the standard setup fee. When these spots are gone, standard pricing applies.\"}]]}],[\"$\",\"div\",null,{\"className\":\"pricing-spots-card\",\"children\":[[\"$\",\"strong\",null,{\"children\":\"10 spots\"}],[\"$\",\"span\",null,{\"children\":\"Limited launch batch\"}],[\"$\",\"div\",null,{\"className\":\"pricing-spots-bar\",\"children\":[\"$\",\"span\",null,{}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"container pricing-table-wrap pricing-access-table-wrap\",\"children\":[\"$\",\"table\",null,{\"className\":\"pricing-simple-table\",\"children\":[[\"$\",\"thead\",null,{\"children\":[\"$\",\"tr\",null,{\"children\":[[\"$\",\"th\",null,{\"children\":\"Plan\"}],[\"$\",\"th\",null,{\"children\":\"Standard Price\"}],[\"$\",\"th\",null,{\"children\":\"Early Access Price\"}],[\"$\",\"th\",null,{\"children\":\"You Save\"}]]}]}],[\"$\",\"tbody\",null,{\"children\":[[\"$\",\"tr\",\"Starte