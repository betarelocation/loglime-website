 to 40 hours per week per property manager.\"]}]]}],\"$L24\",\"$L25\"]}]]}],\"$L26\",\"$L27\",\"$L28\",\"$L29\",\"$L2a\"]}],\"$L2b\"]}]}]]}]\n1b:[\"$\",\"footer\",null,{\"className\":\"blog-footer\",\"children\":[\"$\",\"div\",null,{\"className\":\"blog-footer-inner\",\"children\":[[\"$\",\"div\",null,{\"className\":\"blog-footer-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"blog-footer-brand\",\"children\":[[\"$\",\"a\",null,{\"className\":\"blog-logo\",\"href\":\"/blog\",\"children\":[[\"$\",\"span\",null,{\"className\":\"blog-logo-mark blog-logo-mark-sm\",\"children\":[[\"$\",\"span\",null,{}],[\"$\",\"span\",null,{}],[\"$\",\"span\",null,{}],[\"$\",\"span\",null,{}]]}],[\"$\",\"span\",null,{\"children\":\"NexSaS\"}]]}],[\"$\",\"p\",null,{\"children\":\"Automate manual tasks and provide a premium, modern experience for all property management teams and active tenants.\"}],[\"$\",\"div\",null,{\"className\":\"blog-socials\",\"children\":[[\"$\",\"a\",\"fb\",{\"href\":\"#\",\"children\":\"fb\"}],[\"$\",\"a\",\"ig\",{\"href\":\"#\",\"children\":\"ig\"}],[\"$\",\"a\",\"yt\",{\"href\":\"#\",\"children\":\"yt\"}],[\"$\",\"a\",\"in\",{\"href\":\"#\",\"children\":\"in\"}]]}]]}],[[\"$\",\"div\",\"Company\",{\"className\":\"blog-footer-column\",\"children\":[[\"$\",\"h4\",null,{\"children\":\"Company\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",\"About Us\",{\"children\":[\"$\",\"a\",null,{\"href\":\"#\",\"children\":\"About Us\"}]}],[\"$\",\"li\",\"Career Opportunities\",{\"children\":[\"$\",\"a\",null,{\"href\":\"#\",\"children\":\"Career Opportunities\"}]}],[\"$\",\"li\",\"Case Studies\",{\"children\":[\"$\",\"a\",null,{\"href\":\"#\",\"children\":\"Case Studies\"}]}],[\"$\",\"li\",\"Contact Us\",{\"children\":[\"$\",\"a\",null,{\"href\":\"#\",\"children\":\"Contact Us\"}]}]]}]]}],[\"$\",\"div\",\"Support\",{\"className\":\"blog-footer-column\",\"children\":[[\"$\",\"h4\",null,{\"children\":\"Support\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\"