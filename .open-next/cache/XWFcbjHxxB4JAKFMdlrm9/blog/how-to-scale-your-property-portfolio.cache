strong\",null,{\"children\":\"Automation over hiring:\"}],\" How automating rent collection and maintenance can save up to 40 hours per week per property manager.\"]}]]}],\"$L11\",\"$L12\"]}]]}],\"$L13\",\"$L14\",\"$L15\",\"$L16\",\"$L17\"]}],\"$L18\"]}]}]]}]\nc:[\"$\",\"footer\",null,{\"className\":\"blog-footer\",\"children\":[\"$\",\"div\",null,{\"className\":\"blog-footer-inner\",\"children\":[[\"$\",\"div\",null,{\"className\":\"blog-footer-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"blog-footer-brand\",\"children\":[[\"$\",\"a\",null,{\"className\":\"blog-logo\",\"href\":\"/blog\",\"children\":[[\"$\",\"span\",null,{\"className\":\"blog-logo-mark blog-logo-mark-sm\",\"children\":[[\"$\",\"span\",null,{}],[\"$\",\"span\",null,{}],[\"$\",\"span\",null,{}],[\"$\",\"span\",null,{}]]}],[\"$\",\"span\",null,{\"children\":\"NexSaS\"}]]}],[\"$\",\"p\",null,{\"children\":\"Automate manual tasks and provide a premium, modern experience for all property management teams and active tenants.\"}],[\"$\",\"div\",null,{\"className\":\"blog-socials\",\"children\":[[\"$\",\"a\",\"fb\",{\"href\":\"#\",\"children\":\"fb\"}],[\"$\",\"a\",\"ig\",{\"href\":\"#\",\"children\":\"ig\"}],[\"$\",\"a\",\"yt\",{\"href\":\"#\",\"children\":\"yt\"}],[\"$\",\"a\",\"in\",{\"href\":\"#\",\"children\":\"in\"}]]}]]}],[[\"$\",\"div\",\"Company\",{\"className\":\"blog-footer-column\",\"children\":[[\"$\",\"h4\",null,{\"children\":\"Company\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",\"About Us\",{\"children\":[\"$\",\"a\",null,{\"href\":\"#\",\"children\":\"About Us\"}]}],[\"$\",\"li\",\"Career Opportunities\",{\"children\":[\"$\",\"a\",null,{\"href\":\"#\",\"children\":\"Career Opportunities\"}]}],[\"$\",\"li\",\"Case Studies\",{\"children\":[\"$\",\"a\",null,{\"href\":\"#\",\"children\":\"Case Studies\"}]}],[\"$\",\"li\",\"Contact Us\",{\"children\":[\"$\",\"a\",null,{\"href\":\"#\",\"children\":\"Contact Us\"}]}]]}]]}],[\"$\",\"div\",\"Support\",{\"className\":\"blog-footer